# ─── cTrader Trader Server (ctrader-trader.mjs) ───
# Deploy this server on Railway with these env vars.
#
# To get credentials:
# 1. Register an app at https://openapi.ctrader.com → Applications → Create
# 2. Note your Client ID and Client Secret
# 3. Set a redirect URI (e.g. https://openapi.ctrader.com)
# 4. Visit: https://id.ctrader.com/my/settings/openapi/grantingaccess/?client_id=YOUR_ID&redirect_uri=https://openapi.ctrader.com&scope=trading&product=web
# 5. Login, allow access, then exchange the code for tokens via:
#    curl -X GET "https://openapi.ctrader.com/apps/token?grant_type=authorization_code&code=CODE&redirect_uri=https://openapi.ctrader.com&client_id=YOUR_ID&client_secret=YOUR_SECRET"
# 6. Find your Account ID in cTrader → (your account) → Account ID

CTRADER_CLIENT_ID=your_client_id
CTRADER_CLIENT_SECRET=your_client_secret
CTRADER_REFRESH_TOKEN=your_permanent_refresh_token
CTRADER_ACCOUNT_ID=your_ctrader_account_id

# Set to "true" for demo environment (default: live)
CTRADER_DEMO=true

# Server port (default: 8080)
PORT=8080
