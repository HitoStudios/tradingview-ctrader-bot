# ─── cTrader Trader Server (ctrader-trader.mjs) ───
# Deploy this server on Railway with these env vars.
#
# Option A: CTRADER_ACCESS_TOKEN (easiest, lasts 30 days)
#   Get one by running: .\get-token.ps1
#   When it expires, run get-token.ps1 again and update Railway.
#
# Option B: Permanent refresh token (auto-renewing)
#   Follow the OAuth2 flow to get a refresh token:
#   1. Set redirect URI on your app: https://openapi.ctrader.com
#   2. Open in browser:
#      https://id.ctrader.com/my/settings/openapi/grantingaccess/?client_id=YOUR_ID&redirect_uri=https://openapi.ctrader.com&scope=trading&product=web
#   3. Login → Allow access → paste the redirect URL into:
#      .\get-token.ps1
#   4. Copy the refreshToken from the output

CTRADER_CLIENT_ID=your_client_id
CTRADER_CLIENT_SECRET=your_client_secret
CTRADER_REFRESH_TOKEN=your_permanent_refresh_token
CTRADER_ACCOUNT_ID=your_ctrader_account_id

# Set to "true" for demo environment (default: live)
CTRADER_DEMO=true

# Server port (default: 8080)
PORT=8080

# Optional: use access token directly (skip refresh token, lasts 30 days)
# CTRADER_ACCESS_TOKEN=eyJ...
