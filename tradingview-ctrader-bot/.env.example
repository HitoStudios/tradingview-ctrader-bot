# ─── Vercel Webhook (api/webhook.js) ───
# Relay server URL to forward TradingView signals to.
# Deploy relay-server.mjs on Railway/Render and put its URL here.
RELAY_URL=https://your-relay.up.railway.app

# ─── cTrader Open API Credentials (for reference only) ───
# Not needed by Vercel — used if building a direct WebSocket trader.
# 1. Register an app at https://openapi.ctrader.com → Applications → Create
# 2. Note your Client ID and Client Secret
CTRADER_CLIENT_ID=your_client_id
CTRADER_CLIENT_SECRET=your_client_secret
CTRADER_ACCOUNT_ID=your_ctrader_account_id
