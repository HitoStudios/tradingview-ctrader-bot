# ─── cTrader Open API Credentials ───
# 1. Register an app at https://openapi.ctrader.com → Applications → Create
# 2. Note your Client ID and Client Secret
# 3. In the Playground page, click "Get token" to get a permanent refresh token
# 4. Find your Account ID in cTrader → (your account) → Account ID
#
# ⚠️  cTrader Open API is WebSocket-based (not REST). See README.md for
#     the two approaches to execute trades: cBot or relay server.

CTRADER_CLIENT_ID=your_client_id
CTRADER_CLIENT_SECRET=your_client_secret
CTRADER_REFRESH_TOKEN=your_permanent_refresh_token_from_playground
CTRADER_ACCOUNT_ID=123456
