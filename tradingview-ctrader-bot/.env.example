# ─── cTrader Open API Credentials ───
# 1. Register an app at https://idp.ctrader.com/ to get Client ID & Secret
# 2. Use your cTrader login email & password (password grant with "openapi" scope)
# 3. Find your Account ID in cTrader → Accounts → (your account) → Account ID

CTRADER_CLIENT_ID=your_client_id
CTRADER_CLIENT_SECRET=your_client_secret
CTRADER_EMAIL=your_ctrader_email
CTRADER_PASSWORD=your_ctrader_password
CTRADER_ACCOUNT_ID=123456
